# Copy this file to .env and fill in your own values
# NEVER commit the real .env file

# Telegram Bot token — get from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# Your personal Telegram chat ID — the bot will ONLY talk to this ID
# Get it by messaging @userinfobot on Telegram
CHAT_ID=your_telegram_chat_id_here

# Google Sheets ID — the long string in your Sheet URL
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
SHEET_ID=your_google_sheet_id_here

# Path to your Google service account credentials file
GOOGLE_CREDS=credentials.json
